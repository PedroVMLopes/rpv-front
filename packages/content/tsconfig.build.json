{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "dist-tmp",
    "rootDir": ".",
    "noEmit": false,
    "declaration": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src", "scripts"],
  "exclude": ["__tests__", "src/catalog/bundled.ts", "src/index.ts"]
}
